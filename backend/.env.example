# --- Database ---
DATABASE_URL="postgresql://nuke:nuke@localhost:5432/nuke?schema=public"
# Used only for running migrations. Locally this is the same as DATABASE_URL.
# In production, if your provider offers a pooled connection (e.g. Neon's
# "-pooler" endpoint), put the pooled one in DATABASE_URL and the direct
# (non-pooled) one here — Prisma's migration advisory locks need a direct
# connection, pooled ones can time out (P1002).
DIRECT_URL="postgresql://nuke:nuke@localhost:5432/nuke?schema=public"

# --- Server ---
PORT=4000
CORS_ORIGIN="http://localhost:5173"

# --- Admin ---
# Long random token. Sent by the admin UI as the `x-admin-token` header.
# Generate one with: openssl rand -hex 32
ADMIN_TOKEN="change-me-to-a-long-random-value"

# --- Object storage (S3-compatible) ---
# Local dev: MinIO (see docker-compose.yml). Swap these for Backblaze B2 or
# AWS S3 credentials in production — the client code does not change.
S3_ENDPOINT="http://localhost:9000"
S3_REGION="us-east-1"
S3_ACCESS_KEY_ID="minioadmin"
S3_SECRET_ACCESS_KEY="minioadmin"
S3_BUCKET="nuke-evidence"
S3_FORCE_PATH_STYLE=true
# Public base URL evidence files are served from. With MinIO in dev this is
# the endpoint + bucket; in prod point this at your CDN / bucket public URL.
S3_PUBLIC_BASE_URL="http://localhost:9000/nuke-evidence"

# --- Rate limiting ---
# Secret mixed into the daily-rotating IP hash salt. Never logged, never
# persisted alongside content.
RATE_LIMIT_SECRET="change-me-too"
RATE_LIMIT_MAX_REPORTS_PER_HOUR=5

# --- Virus scanning (optional) ---
# If clamd is not reachable, uploads are simply not scanned (logged once).
CLAMAV_HOST="localhost"
CLAMAV_PORT=3310

# --- Kenya politics news (optional) ---
# Free API key from https://newsdata.io — without this, GET /api/news just
# returns an empty list (configured: false) rather than erroring.
NEWSDATA_API_KEY=""
